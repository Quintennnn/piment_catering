---
layout: base.njk
title: Piment Catering - Menu
---

<section class="section">
  <div class="container">
    <h1 style="text-align: center;">Ons Menu</h1>
    <p style="text-align: center; max-width: 600px; margin: 0 auto 3rem auto;">
      Dit menu wordt volledig beheerd via het CMS. Hieronder ziet u de gerechten die u zelf heeft ingevoerd.
    </p>

    <!-- Loop door alle menu data bestanden in _data/menu/ -->
    {% for key, menuData in menu %}
      <div style="margin-bottom: 4rem; max-width: 800px; margin-left: auto; margin-right: auto;">
        <h2 style="color: var(--color-primary); border-bottom: 2px solid var(--color-surface); padding-bottom: 0.5rem; margin-bottom: 2rem;">
          {{ menuData.category }}
        </h2>
        
        <ul style="list-style: none; padding: 0;">
          {% for item in menuData.items %}
            <li style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 1.5rem;">
              <div>
                <h3 style="margin-bottom: 0.25rem;">{{ item.name }}</h3>
                {% if item.description %}
                  <p style="margin: 0; font-size: 0.9rem;">{{ item.description }}</p>
                {% endif %}
              </div>
              <div style="font-weight: bold; color: var(--color-text); margin-left: 1rem;">
                {{ item.price }}
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>
    {% endfor %}

  </div>
</section>
