<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default(site.name) }}</title>
  <meta name="description" content="{{ description | default(site.footer_text) }}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/index.css">
  <link rel="icon" type="image/avif" href="/assets/images/logo.avif">

  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body>

  <header class="header">
    <div class="container nav">
      <a href="/" class="logo" aria-label="{{ site.name }} - home">
        <img src="/assets/images/logo.avif" alt="{{ site.name }}" class="logo-img">
      </a>
      <button class="nav-toggle" aria-label="Menu openen" aria-expanded="false" aria-controls="primary-nav">
        <span></span><span></span><span></span>
      </button>
      <ul class="nav-links" id="primary-nav">
        {% for item in site.nav %}
          <li><a href="{{ item.url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </header>

  <main>
    {{ content | safe }}
  </main>

  <footer class="footer">
    <div class="container footer-grid">
      <div>
        <img src="/assets/images/logo.avif" alt="{{ site.name }}" class="logo-img footer-logo">
        <p class="body-lg" style="margin-top: var(--spacing-4); max-width: 28ch;">{{ site.footer_text }}</p>
      </div>
      <div>
        <span class="label-md" style="color: var(--tertiary);">Bezoek ons</span>
        <p style="margin-top: var(--spacing-2); margin-bottom: 0;">{{ site.lunchcafe_address.location }}</p>
        <p style="margin-bottom: 0;">{{ site.lunchcafe_address.street }}, {{ site.lunchcafe_address.city }}</p>
        <p style="color: var(--secondary); margin-top: var(--spacing-2);">{{ site.lunchcafe_address.hours }}</p>
      </div>
      <div>
        <span class="label-md" style="color: var(--tertiary);">Contact</span>
        <p style="margin-top: var(--spacing-2); margin-bottom: 0;">
          <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a>
        </p>
        <p style="margin-bottom: 0;">
          <a href="tel:{{ site.contact.phone_link }}">{{ site.contact.phone }}</a>
        </p>
        <p style="margin-top: var(--spacing-2); margin-bottom: 0;">KvK {{ site.kvk }}</p>
      </div>
    </div>
    <div class="container footer-bottom">
      <p>&copy; 2026 {{ site.name }}. Alle rechten voorbehouden.</p>
      <p><a href="/privacyverklaring/">Privacyverklaring</a></p>
    </div>
  </footer>

  <script>
    // Mobile nav toggle
    (function() {
      var btn = document.querySelector('.nav-toggle');
      var nav = document.getElementById('primary-nav');
      if (!btn || !nav) return;
      btn.addEventListener('click', function() {
        var open = nav.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    })();

    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
