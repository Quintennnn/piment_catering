<!-- High-End Editorial Hero -->
<section class="section container" style="padding-top: var(--spacing-12);">
  <div style="max-width: 900px; margin: 0 auto; text-align: center;">
    <span class="label-md" style="color: var(--secondary);">The Curated Earth</span>
    <h1 class="display-lg" style="margin-top: var(--spacing-4); margin-bottom: var(--spacing-8);">Wereldse smaken,<br>liefde uit de buurt.</h1>
    <p class="body-lg" style="max-width: 600px; margin: 0 auto var(--spacing-8) auto;">
      Geniet van heerlijk vegetarisch eten, bereid met zorg, creativiteit en lokale biologische ingrediënten. Een uitnodiging in onze zongedroogde tuin.
    </p>
    <a href="/lunchcafe" class="btn btn-primary">Ontdek ons menu</a>
  </div>
</section>

<!-- Artisanal Gallery / Lunchcafe -->
<section class="section-bg-shift">
  <div class="container">
    <div style="display: grid; grid-template-columns: 1fr; gap: var(--spacing-16); align-items: center;">
      <div class="artisanal-gallery">
        <img src="/assets/images/hero-home.jpg" alt="Piment food presentation" class="artisanal-img artisanal-img-1">
        <img src="/assets/images/cafe-interior.jpg" alt="Lunchcafé interior" class="artisanal-img artisanal-img-2">
      </div>
      
      <div style="max-width: 600px; margin: 0 auto; text-align: center;">
        <h2>Vegetarisch lunchcafé Piment</h2>
        <p class="body-lg">
          Op Landgoed de Rading serveren wij heerlijke biologische koffie, thee en frisdrank met taart en cake. Ook ben je van maandag - zaterdag welkom om te komen lunchen.
        </p>
        <span class="chip" style="margin-bottom: var(--spacing-8);">Keuken open tot 16:00</span>
        <br>
        <a href="/contact" class="btn btn-secondary">Neem contact met ons op</a>
      </div>
    </div>
  </div>
</section>

<!-- Catering Block -->
<section class="section container">
  <div style="display: grid; grid-template-columns: 1fr; gap: var(--spacing-12); align-items: center;">
    
    <div style="text-align: left; max-width: 500px; margin-left: auto;">
      <h2>Vegetarische catering op maat</h2>
      <p class="body-lg">
        Bij Piment kun je terecht voor vegetarische catering op maat. Of het nu gaat om een zakelijke lunch, feest of evenement: wij verzorgen alle gerechten met zorg, creativiteit en aandacht. We gebruiken lokale, duurzame en biologische ingrediënten.
      </p>
      <a href="/catering" class="btn btn-primary">Stuur ons je wensen</a>
    </div>

    <div>
      <img src="/assets/images/chef-catering.jpg" alt="Chef preparing catering" style="width: 100%; border-radius: var(--radius-xl) var(--radius-lg) var(--radius-lg) var(--radius-xl); box-shadow: var(--ambient-shadow);">
    </div>

  </div>
</section>

