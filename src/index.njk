---
layout: base.njk
pagination:
  data: locales.list
  size: 1
  alias: lang
permalink: "{% if lang == 'en' %}/en/{% else %}/{% endif %}"

title:
  nl: "Piment Catering — Wereldse smaken, liefde uit de buurt"
  en: "Piment Catering — World flavors, love from the neighborhood"
description:
  nl: "Vegetarisch lunchcafé en catering op Landgoed de Rading in Hilversum. Wereldse smaken, lokale biologische ingrediënten."
  en: "Vegetarian lunch café and catering at Landgoed de Rading in Hilversum. World flavors, local organic ingredients."

# Hero
hero_label:
  nl: "Wereldse smaken, liefde uit de buurt"
  en: "World flavors, love from the neighborhood"
hero_title:
  nl: "Lekker vegetarisch eten in het groen"
  en: "Delicious vegetarian food in nature"
hero_text:
  nl: "Vegetarisch lunchcafé Piment ligt midden in het groen op Landgoed de Rading. We werken met biologische groenten en kruiden uit zelfoogsttuin Bodemvrucht en serveren wereldse smaken met liefde uit de buurt."
  en: "Vegetarian lunch café Piment sits in the middle of nature at Landgoed de Rading. We work with organic vegetables and herbs from self-harvest garden Bodemvrucht and serve world flavors with love from the neighborhood."
hero_cta_label:
  nl: "Bekijk het lunchcafé"
  en: "Explore the lunch café"
hero_cta_url: /lunchcafe/
hero_secondary_label:
  nl: "Of vraag catering aan"
  en: "Or request catering"
hero_secondary_url: /catering/
hero_image_main: /assets/images/lunchcafe-1.jpg
hero_image_overlap: /assets/images/catering-3.jpg

# Lunchcafé block
lunchcafe_label:
  nl: "Het lunchcafé"
  en: "The lunch café"
lunchcafe_title:
  nl: "Genieten in het groen"
  en: "Enjoy yourself in nature"
lunchcafe_text:
  nl: "Bij vegetarisch lunchcafé Piment op Landgoed de Rading serveren wij heerlijke biologische koffie, thee en frisdrank met taart en cake. Van maandag tot en met zaterdag ben je welkom om te komen lunchen of iets lekkers af te halen."
  en: "At vegetarian lunch café Piment on Landgoed de Rading we serve delicious organic coffee, tea and soft drinks with pies and cakes. From Monday to Saturday you're welcome to come for lunch or pick up something tasty."
lunchcafe_chip:
  nl: "Open ma-za 10:00 – 17:00"
  en: "Open Mon-Sat 10:00 – 17:00"
lunchcafe_cta_label:
  nl: "Bekijk menu en openingstijden"
  en: "See menu and opening hours"
lunchcafe_cta_url: /lunchcafe/
lunchcafe_polaroids:
  - /assets/images/lunchcafe-2.jpg
  - /assets/images/lunchcafe-3.jpg
  - /assets/images/chef-jimy.jpg

# Catering block
catering_label:
  nl: "Catering op maat"
  en: "Tailored catering"
catering_title:
  nl: "Jouw event slaagt met Piment"
  en: "Your event shines with Piment"
catering_text:
  nl: "Bij Piment kun je terecht voor vegetarische catering op maat. Of het nu gaat om een zakelijke lunch, feest of evenement — wij verzorgen alle gerechten met zorg, creativiteit en aandacht. We gebruiken lokale, duurzame en biologische ingrediënten."
  en: "Piment is your address for tailored vegetarian catering. Whether it's a business lunch, party or event — we prepare every dish with care, creativity and attention. We use local, sustainable and organic ingredients."
catering_image: /assets/images/catering-1.jpg
catering_cta_label:
  nl: "Stuur ons je wensen"
  en: "Tell us what you need"
catering_cta_url: /catering/

# Closing CTA
closing_label:
  nl: "Welkom in onze tuin"
  en: "Welcome to our garden"
closing_title:
  nl: "Kom langs, of laat ons komen koken"
  en: "Drop by, or let us come and cook"
closing_text:
  nl: "Of je nu een rustige lunch wilt op het landgoed of een feest wilt laten cateren — bij Piment denken we graag mee. We horen graag van je."
  en: "Whether you want a quiet lunch at the estate or have an event you'd like catered — we're happy to think along with you. We'd love to hear from you."
closing_image: /assets/images/catering-4.jpg
closing_primary_label:
  nl: "Plan een bezoek"
  en: "Plan a visit"
closing_primary_url: /lunchcafe/
closing_secondary_label:
  nl: "Vraag catering aan"
  en: "Request catering"
closing_secondary_url: /catering/
---

<!-- ===================== HERO ===================== -->
<section class="hero-section">
  <div class="container hero-grid">
    <div class="hero-text">
      <span class="label-md" style="color: var(--secondary);">{{ hero_label | t(lang) }}</span>
      <h1 class="display-lg">{{ hero_title | t(lang) }}</h1>
      <p class="body-lg" style="max-width: 50ch;">{{ hero_text | t(lang) }}</p>
      <div class="hero-actions">
        <a href="{{ hero_cta_url | localizedUrl(lang) }}" class="btn btn-primary">{{ hero_cta_label | t(lang) }}</a>
        {% if hero_secondary_label %}
          <a href="{{ hero_secondary_url | localizedUrl(lang) }}" class="link-arrow">{{ hero_secondary_label | t(lang) }} →</a>
        {% endif %}
      </div>
      <p class="hero-meta">
        <span class="dot"></span>
        {{ site.lunchcafe_address.hours | t(lang) }}
      </p>
    </div>
    <div class="hero-images">
      <img src="{{ hero_image_main }}" alt="Lunchcafé Piment" class="hero-image-main">
      {% if hero_image_overlap %}
        <img src="{{ hero_image_overlap }}" alt="" class="hero-image-overlap">
      {% endif %}
    </div>
  </div>
</section>

<!-- ===================== LUNCHCAFÉ ===================== -->
<section class="section-bg-shift">
  <div class="container">
    <div class="split-grid">
      <div class="split-text">
        <span class="label-md" style="color: var(--secondary);">{{ lunchcafe_label | t(lang) }}</span>
        <h2 style="margin-top: var(--spacing-4);">{{ lunchcafe_title | t(lang) }}</h2>
        <p class="body-lg">{{ lunchcafe_text | t(lang) }}</p>
        <span class="chip" style="margin-bottom: var(--spacing-8);">{{ lunchcafe_chip | t(lang) }}</span>
        <div style="margin-top: var(--spacing-6);">
          <a href="{{ lunchcafe_cta_url | localizedUrl(lang) }}" class="btn btn-secondary">{{ lunchcafe_cta_label | t(lang) }}</a>
        </div>
      </div>
      <div class="polaroid-row">
        {% for img in lunchcafe_polaroids %}
          <img src="{{ img }}" alt="" loading="lazy">
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<!-- ===================== CATERING ===================== -->
<section class="section container">
  <div class="split-grid split-grid-reverse">
    <div class="split-image">
      <img src="{{ catering_image }}" alt="" style="width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-md) var(--radius-xl) var(--radius-xl) var(--radius-md); box-shadow: var(--ambient-shadow);">
    </div>
    <div class="split-text">
      <span class="label-md" style="color: var(--secondary);">{{ catering_label | t(lang) }}</span>
      <h2 style="margin-top: var(--spacing-4);">{{ catering_title | t(lang) }}</h2>
      <p class="body-lg">{{ catering_text | t(lang) }}</p>
      <a href="{{ catering_cta_url | localizedUrl(lang) }}" class="btn btn-primary">{{ catering_cta_label | t(lang) }}</a>
    </div>
  </div>
</section>

<!-- ===================== PULL-QUOTE TESTIMONIAL ===================== -->
<section class="section-bg-shift">
  <div class="container" style="max-width: 900px;">
    {% if testimonials.items[0] %}
      <figure class="pullquote">
        <span class="label-md pullquote-stars">
          {%- for i in range(0, testimonials.items[0].rating) -%}★{%- endfor -%}
        </span>
        <blockquote>"{{ testimonials.items[0].quote | t(lang) }}"</blockquote>
        <figcaption>— {{ testimonials.items[0].name }}</figcaption>
      </figure>
    {% endif %}

    {% if testimonials.items.length > 1 %}
      <div class="testimonials-secondary">
        {% for tItem in testimonials.items %}
          {% if loop.index > 1 %}
            <div class="testimonial-mini">
              <span class="label-md" style="color: var(--tertiary);">
                {%- for i in range(0, tItem.rating) -%}★{%- endfor -%}
              </span>
              <p>"{{ tItem.quote | t(lang) }}"</p>
              <span class="testimonial-mini-name">— {{ tItem.name }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<!-- ===================== CLOSING CTA ===================== -->
<section class="closing-cta">
  <div class="container">
    <div class="closing-cta-card">
      <div class="closing-cta-image">
        <img src="{{ closing_image }}" alt="" loading="lazy">
      </div>
      <div class="closing-cta-text">
        <span class="label-md" style="color: var(--secondary);">{{ closing_label | t(lang) }}</span>
        <h2 style="margin-top: var(--spacing-4);">{{ closing_title | t(lang) }}</h2>
        <p class="body-lg">{{ closing_text | t(lang) }}</p>
        <div class="hero-actions">
          <a href="{{ closing_primary_url | localizedUrl(lang) }}" class="btn btn-primary">{{ closing_primary_label | t(lang) }}</a>
          <a href="{{ closing_secondary_url | localizedUrl(lang) }}" class="btn btn-secondary">{{ closing_secondary_label | t(lang) }}</a>
        </div>
      </div>
    </div>
  </div>
</section>
